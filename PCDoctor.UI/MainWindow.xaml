<Window x:Class="PCDoctor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="PCDoctor"
        Height="850"
        Width="1150"
        MinHeight="800"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#151B2E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A9B7D8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F9BB8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,20,0"/>
        </Style>

        <Style x:Key="DeviceTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6F7FA6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,20,0"/>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#24304F"/>
            <Setter Property="Foreground" Value="#EAF0FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#334166"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#1D2742"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvisibleRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#3C4664"
                                CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb/>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#D7DEF5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Foreground" Value="#D7DEF5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#222B45"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#1D263E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#29324A"/>
            <Setter Property="Foreground" Value="LightGreen"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="125"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="PCDoctor"
                           FontSize="36"
                           FontWeight="Bold"/>

                <TextBlock Text="System Monitoring &amp; Diagnostics"
                           FontSize="15"
                           Foreground="#8F9BB8"
                           Margin="0,4,0,0"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Dashboard.ApiStatusText}"
                               Foreground="{Binding Dashboard.ApiStatusBrush}"
                               FontSize="13"
                               Margin="0,8,20,0"/>

                    <TextBlock Text="{Binding Dashboard.LastSyncText}"
                               Style="{StaticResource StatusTextStyle}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Dashboard.DeviceNameText}"
                               Style="{StaticResource DeviceTextStyle}"/>

                    <TextBlock Text="{Binding Dashboard.DeviceIdText}"
                               Style="{StaticResource DeviceTextStyle}"/>

                    <TextBlock Text="{Binding Dashboard.OperatingSystemText}"
                               Style="{StaticResource DeviceTextStyle}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Settings"
                    Width="110"
                    Height="38"
                    Margin="0,8,10,0"
                    Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource SettingsButtonStyle}"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="CPU Usage" Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="{Binding Dashboard.CpuUsageText}"
                               FontSize="44"
                               FontWeight="Bold"
                               Margin="0,16,0,18"/>

                    <ProgressBar Value="{Binding Dashboard.CpuProgressValue}"
                                 Foreground="{Binding Dashboard.CpuProgressBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Memory Usage" Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="{Binding Dashboard.MemoryUsageText}"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,22,0,20"/>

                    <ProgressBar Value="{Binding Dashboard.MemoryProgressValue}"
                                 Foreground="{Binding Dashboard.MemoryProgressBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Top Processes" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,14,0,0">
                        <ItemsControl ItemsSource="{Binding Dashboard.ProcessItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="#D7DEF5"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,0,8,6"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="System Health"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Grid Grid.Row="1"
                          Margin="0,10,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Dashboard.HealthScoreText}"
                                   FontSize="36"
                                   FontWeight="Bold"/>

                        <Border Grid.Column="1"
                                Background="#222B45"
                                CornerRadius="10"
                                Padding="10,5"
                                Margin="14,10,0,0"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding Dashboard.HealthStatusText}"
                                       Foreground="{Binding Dashboard.HealthStatusBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <ProgressBar Grid.Row="2"
                                 Value="{Binding Dashboard.HealthProgressValue}"
                                 Foreground="{Binding Dashboard.HealthStatusBrush}"
                                 Margin="0,0,0,12"/>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding Dashboard.HealthSummaryText}"
                                   Foreground="#8F9BB8"
                                   FontSize="13"
                                   Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Detected Issues"
                                           Foreground="#A9B7D8"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Margin="0,6,0,0">
                                    <ItemsControl ItemsSource="{Binding Dashboard.HealthReasonItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#D7DEF5"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,8,6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Recommendations"
                                           Foreground="#A9B7D8"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Margin="0,6,0,0">
                                    <ItemsControl ItemsSource="{Binding Dashboard.HealthRecommendationItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#D7DEF5"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,8,6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="History" Style="{StaticResource SectionTitleStyle}"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,10,0,0">
                            <ItemsControl ItemsSource="{Binding Dashboard.HistoryItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#D7DEF5"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,8,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionTitleStyle}"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,10,0,0">
                            <ItemsControl ItemsSource="{Binding Dashboard.DiagnosticItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#D7DEF5"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,8,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Disk Usage"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding Dashboard.DiskItems}"
                                  Margin="0,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#D7DEF5"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,0,8,6"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CPU History" Style="{StaticResource SectionTitleStyle}"/>

                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding Dashboard.CpuSeries}"
                                        XAxes="{Binding Dashboard.CpuXAxes}"
                                        YAxes="{Binding Dashboard.CpuYAxes}"
                                        DrawMarginFrame="{Binding Dashboard.CpuDrawMarginFrame}"
                                        Background="Transparent"
                                        LegendPosition="Hidden"
                                        TooltipPosition="Hidden"
                                        Height="190"
                                        Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>