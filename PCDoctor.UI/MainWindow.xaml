<Window x:Class="PCDoctor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PCDoctor.UI.Views"
        xmlns:pages="clr-namespace:PCDoctor.UI.Views.Pages"
        Title="PCDoctor"
        Height="850"
        Width="1350"
        MinHeight="800"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Window.Resources>
        <Style x:Key="SidebarItemStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="#8F9BB8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="16,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1B2338"/>
                                <Setter Property="Foreground" Value="#EAF0FF"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#24304F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageVisibilityStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0F1628"
                BorderBrush="#1F2A44"
                BorderThickness="0,0,1,0"
                Padding="22">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="PCDoctor"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="System Monitor"
                               Foreground="#6F7FA6"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <RadioButton Content="Overview"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsOverviewSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarItemStyle}"/>

                    <RadioButton Content="Diagnostics"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsDiagnosticsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarItemStyle}"/>

                    <RadioButton Content="Reports"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsReportsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarItemStyle}"/>

                    <RadioButton Content="History"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsHistorySelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarItemStyle}"/>

                    <RadioButton Content="Processes"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsProcessesSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarItemStyle}"/>

                    <RadioButton Content="Settings"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsSettingsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarItemStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="{Binding Dashboard.ApiStatusText}"
                               Foreground="{Binding Dashboard.ApiStatusBrush}"
                               FontSize="12"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding Dashboard.LastSyncText}"
                               Foreground="#6F7FA6"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="92"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0B1020"
                    Padding="28,20,28,10">

                <StackPanel>
                    <TextBlock Text="{Binding PageTitle}"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding PageSubtitle}"
                               Foreground="#8F9BB8"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">

                <views:DashboardView>
                    <views:DashboardView.Style>
                        <Style TargetType="{x:Type views:DashboardView}" BasedOn="{StaticResource PageVisibilityStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="Overview">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:DashboardView.Style>
                </views:DashboardView>

                <pages:DiagnosticsView>
                    <pages:DiagnosticsView.Style>
                        <Style TargetType="{x:Type pages:DiagnosticsView}" BasedOn="{StaticResource PageVisibilityStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="Diagnostics">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:DiagnosticsView.Style>
                </pages:DiagnosticsView>

                <pages:ReportsView>
                    <pages:ReportsView.Style>
                        <Style TargetType="{x:Type pages:ReportsView}" BasedOn="{StaticResource PageVisibilityStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="Reports">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:ReportsView.Style>
                </pages:ReportsView>

                <pages:HistoryView>
                    <pages:HistoryView.Style>
                        <Style TargetType="{x:Type pages:HistoryView}" BasedOn="{StaticResource PageVisibilityStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="History">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:HistoryView.Style>
                </pages:HistoryView>

                <pages:ProcessesView>
                    <pages:ProcessesView.Style>
                        <Style TargetType="{x:Type pages:ProcessesView}" BasedOn="{StaticResource PageVisibilityStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="Processes">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:ProcessesView.Style>
                </pages:ProcessesView>

                <pages:SettingsView>
                    <pages:SettingsView.Style>
                        <Style TargetType="{x:Type pages:SettingsView}" BasedOn="{StaticResource PageVisibilityStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="Settings">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </pages:SettingsView.Style>
                </pages:SettingsView>

            </Grid>
        </Grid>
    </Grid>
</Window>