<UserControl x:Class="PCDoctor.UI.Views.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020">

    <Border Background="#151B2E"
            CornerRadius="18"
            Padding="28"
            Margin="28">

        <StackPanel>
            <TextBlock Text="Settings"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBlock Text="The current SettingsWindow will be converted into this page later."
                       Foreground="#8F9BB8"
                       FontSize="14"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</UserControl>