<UserControl x:Class="PCDoctor.UI.Views.Pages.ProcessesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#151B2E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#10172A"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="MinHeight" Value="96"/>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F9BB8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F9BB8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F9BB8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D7DEF5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="InvisibleRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#3C4664"
                                CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb/>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource InvisibleRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#29324A"/>
            <Setter Property="Foreground" Value="LightGreen"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>

                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Processes"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock Grid.Row="1"
                           Text="Full list of memory-heavy processes reported by the monitoring service, sorted by highest memory usage."
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,8,0,22"/>

                <Grid Grid.Row="2"
                      Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="MONITORED"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Dashboard.ProcessCountText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="HEAVIEST PROCESS"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Dashboard.HeaviestProcessText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource SummaryCardStyle}"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="MEMORY PRESSURE"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Dashboard.ProcessAlertText}"
                                       Foreground="{Binding Dashboard.ProcessAlertBrush}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="3"
                      Background="#10172A"
                      MinHeight="42"
                      Margin="0,0,8,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="#"
                               Style="{StaticResource TableHeaderTextStyle}"
                               Margin="14,0,0,0"/>

                    <TextBlock Grid.Column="1"
                               Text="PROCESS"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="2"
                               Text="PID"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="3"
                               Text="MEMORY"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="4"
                               Text="LEVEL"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="5"
                               Text="USAGE"
                               Style="{StaticResource TableHeaderTextStyle}"/>
                </Grid>

                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Dashboard.ProcessRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10172A"
                                        CornerRadius="12"
                                        Padding="0"
                                        MinHeight="58"
                                        Margin="0,0,8,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding PositionText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="#8F9BB8"
                                                   Margin="14,0,0,0"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ProcessName}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ProcessId}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="#A9B7D8"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding MemoryUsageText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   FontWeight="SemiBold"/>

                                        <Border Grid.Column="4"
                                                Background="#222B45"
                                                CornerRadius="10"
                                                Padding="10,5"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MemoryLevelText}"
                                                       Foreground="{Binding MemoryUsageBrush}"
                                                       FontSize="12"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <ProgressBar Grid.Column="5"
                                                     Value="{Binding MemoryUsageBarValue, Mode=OneWay}"
                                                     Foreground="{Binding MemoryUsageBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,18,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>