<Window x:Class="PCDoctor.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PCDoctor.UI"
        mc:Ignorable="d"
        Title="Settings"
        Height="520"
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#0B1020">

    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Settings"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,24"/>

            <TextBlock Text="API Base URL" Foreground="#A9B7D8"/>
            <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,6,0,16"/>

            <TextBlock Text="Refresh Interval (seconds)" Foreground="#A9B7D8"/>
            <TextBox Text="{Binding RefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,6,0,16"/>

            <TextBlock Text="API Upload Interval (seconds)" Foreground="#A9B7D8"/>
            <TextBox Text="{Binding ApiSendIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,6,0,20"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#FF6B6B"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"/>

            <Separator Margin="0,4,0,20"/>

            <TextBlock Text="Device Registration"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#A9B7D8"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Resetting the local device registration deletes the stored device token. PCDoctor will register as a new device on the next sync."
                       Foreground="#8F9BB8"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Button Content="Reset Device Registration"
                    Width="210"
                    Height="36"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,28"
                    Command="{Binding ResetDeviceRegistrationCommand}"/>

            <Button Content="Save"
                    Width="120"
                    Height="36"
                    HorizontalAlignment="Right"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>